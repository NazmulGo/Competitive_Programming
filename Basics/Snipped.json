      "  vector<pair<ll, ll>>hull; k=hull.size();",
      "",
      "  for(ll i=0; i<n; i++) {",
      "    m = hull.size();",
      "    while( m >= k+2 && point_location(hull[m-2].first, hull[m-2].second, hull[m-1].first, hull[m-1].second, p[i].first, p[i].second) > 0) {  // >=0 dile same point thakle mibe na",
