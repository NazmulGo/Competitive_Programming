      "    }",
      "    hull.push_back(p[i]);",
      "  }",
      "",
      "  hull.pop_back(); ",
      "  k=hull.size();",
      "",
      "  for(ll i=n-1; i>=0; i--) {",
      "    m = hull.size();",
